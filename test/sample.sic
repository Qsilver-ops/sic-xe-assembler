COPY    START   0
FIRST   STL     RETADR
CLOOP   JSUB    RDREC
        LDA     LENGTH
        COMP    ZERO
        JEQ     ENDFIL
        JSUB    WRREC
        J       CLOOP
ENDFIL  LDA     EOF
        STA     BUFFER
        LDL     RETADR
        RSUB
RETADR  RESW    1
LENGTH  RESW    1
ZERO    WORD    0
EOF     BYTE    C'EOF'
BUFFER  RESB    4096
        END     FIRST
